[Unit]
Description=UniFi Admin Portal
After=network-online.target camera-toggle.service door-lock-toggle.service
Wants=network-online.target

[Service]
Type=simple
User=lherzog
WorkingDirectory=/opt/unifi-admin-portal
ExecStart=/opt/unifi-admin-portal/.venv/bin/python3 app.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
